---
interface Props {
  lang: "en" | "zh-CN";
  homeHref: string;
  introHref: string;
  quickStartHref: string;
  integrationHref: string;
  providersHref: string;
  faqHref: string;
  githubHref: string;
  nav: {
    intro: string;
    quickStart: string;
    integration: string;
    providers: string;
    github: string;
  };
  eyebrow: string;
  title: string;
  description: string;
  primaryCta: string;
  secondaryCta: string;
  coverageTitle: string;
  coverageItems: string[];
  sectionTitle: string;
  sectionLead: string;
  cards: Array<{
    title: string;
    body: string;
    href: string;
    cta: string;
  }>;
}

const props = Astro.props as Props;
import logo from "../assets/logo.svg";
import rootPackage from "../../../../package.json";
import "../styles/site.css";
const withBase = (path: string) => {
  const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
  const relative = path.replace(/^\//, "");
  return `${base}${relative}`;
};
const siteUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const canonicalUrl = siteUrl.toString();
const releaseVersion = rootPackage.version;
const releaseTag = `v${releaseVersion}`;
const releaseBase = `https://github.com/xiaoyuandev/ai-relay-box/releases/download/${releaseTag}`;
const latestReleaseHref = "https://github.com/xiaoyuandev/ai-relay-box/releases/latest";
const installCommand = "curl -fsSL https://raw.githubusercontent.com/xiaoyuandev/ai-relay-box/main/scripts/install.sh | bash";
const downloadLinks = [
  {
    label: props.lang === "zh-CN" ? "macOS Apple Silicon" : "macOS Apple Silicon",
    meta: props.lang === "zh-CN" ? "DMG, arm64" : "DMG, arm64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-arm64.dmg`
  },
  {
    label: props.lang === "zh-CN" ? "macOS Intel" : "macOS Intel",
    meta: props.lang === "zh-CN" ? "DMG, x64" : "DMG, x64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-x64.dmg`
  },
  {
    label: props.lang === "zh-CN" ? "Windows" : "Windows",
    meta: props.lang === "zh-CN" ? "安装程序, x64" : "Installer, x64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-x64-setup.exe`
  },
  {
    label: props.lang === "zh-CN" ? "Linux Desktop" : "Linux Desktop",
    meta: props.lang === "zh-CN" ? "AppImage, x64" : "AppImage, x64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-x64.AppImage`
  }
];
const seoMeta =
  props.lang === "zh-CN"
    ? {
        title: "AI Relay Box - 本地 OpenAI 兼容 AI 网关",
        description:
          "AI Relay Box 让 Cursor、Claude Code、Codex、Cherry Studio 和脚本共用一个本地 OpenAI 兼容端点，并通过桌面 UI 管理多个 AI 服务商和模型来源。",
        keywords:
          "AI Relay Box, 本地 AI 网关, OpenAI 兼容网关, Cursor 中转配置, Claude Code OpenAI, Codex 本地网关, new-api, one-api",
        downloadTitle: "下载并开始使用",
        downloadLead:
          "从 GitHub Release 下载桌面端，或在 WSL / Linux Server 上使用一键安装命令启动本地网关。",
        githubCta: "获取 AI Relay Box",
        releaseCta: "查看全部 Release",
        serverTitle: "WSL / Linux Server 一键安装",
        serverHint: "安装后默认 Web 管理界面和 OpenAI 兼容入口都运行在 http://127.0.0.1:3456。",
        installSectionTitle: "安装和使用",
        installSectionLead: "选择桌面端直接下载，或在 WSL / Linux Server 上使用一键安装脚本。安装完成后，把你的工具统一指向本地 OpenAI 兼容入口。",
        desktopTitle: "桌面端下载",
        docsTitle: "需要完整接入步骤？",
        docsLead: "详细文档包含 Provider 配置、工具接入、Deep Link 导入和常见问题。",
        docsCta: "查看详细文档",
        endpointLabel: "本地端点",
        galleryLabel: "产品预览",
        galleryTitle: "在一个桌面界面里管理 Provider、模型来源和请求日志",
        galleryLead: "查看核心界面截图。后续继续添加截图时只需要扩展图片列表。",
        previousSlide: "上一张截图",
        nextSlide: "下一张截图",
        heroPoints: [
          "为 Cursor、Claude Code、Codex、Cherry Studio 和脚本提供一个本地 OpenAI 兼容入口",
          "在桌面 UI 中统一管理多个大模型中转 API、模型来源、健康检查和请求日志",
          "切换上游服务时不需要反复修改每个工具的 Base URL 和模型配置"
        ],
      }
    : {
        title: "AI Relay Box - Local AI Gateway for OpenAI-Compatible Tools",
        description:
          "AI Relay Box gives Cursor, Claude Code, Codex, Cherry Studio, and scripts one local OpenAI-compatible endpoint, with provider and model switching from a desktop UI.",
        keywords:
          "AI Relay Box, local AI gateway, OpenAI compatible gateway, Cursor OpenAI proxy, Claude Code OpenAI compatible, Codex local gateway, new-api, one-api",
        downloadTitle: "Download and start using AI Relay Box",
        downloadLead:
          "Download the desktop app from GitHub Releases, or run the one-line installer for WSL and Linux Server.",
        githubCta: "Get AI Relay Box",
        releaseCta: "View all releases",
        serverTitle: "WSL / Linux Server one-line install",
        serverHint: "After installation, the Web UI and OpenAI-compatible endpoint run on http://127.0.0.1:3456 by default.",
        installSectionTitle: "Install and use",
        installSectionLead: "Download the desktop app, or run the one-line installer on WSL and Linux Server. After installation, point your tools to one local OpenAI-compatible endpoint.",
        desktopTitle: "Desktop downloads",
        docsTitle: "Need the full setup flow?",
        docsLead: "The docs cover provider configuration, tool integration, Deep Link import, and common setup questions.",
        docsCta: "Read the detailed docs",
        endpointLabel: "Local endpoint",
        galleryLabel: "Product Preview",
        galleryTitle: "Manage providers, model sources, and request logs from one desktop UI",
        galleryLead: "Browse the core interface screenshots. Add more screenshots later by extending the image list.",
        previousSlide: "Previous screenshot",
        nextSlide: "Next screenshot",
        heroPoints: [
          "Give Cursor, Claude Code, Codex, Cherry Studio, and scripts one local OpenAI-compatible endpoint",
          "Manage multiple LLM relay APIs, model sources, health checks, and request logs from a desktop UI",
          "Switch upstream services without editing every tool's Base URL and model configuration"
        ],
      };
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "AI Relay Box",
  applicationCategory: "DeveloperApplication",
  operatingSystem: ["macOS", "Windows", "Linux"],
  description: seoMeta.description,
  url: canonicalUrl,
  downloadUrl: latestReleaseHref,
  softwareVersion: releaseVersion,
  codeRepository: "https://github.com/xiaoyuandev/ai-relay-box",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};

const galleryImages = [
  {
    src: "/img/home-preview.png",
    alt: props.lang === "zh-CN" ? "AI Relay Box 首页概览" : "AI Relay Box home overview"
  },
  {
    src: "/img/quick-start-provider-form.png",
    alt: props.lang === "zh-CN" ? "AI Relay Box Provider 配置表单" : "AI Relay Box provider configuration form"
  },
  {
    src: "/img/quick-start-request-log.png",
    alt: props.lang === "zh-CN" ? "AI Relay Box 请求日志页面" : "AI Relay Box request logs"
  },
  {
    src: "/img/connectatool.png",
    alt: props.lang === "zh-CN" ? "AI Relay Box 工具接入配置" : "AI Relay Box tool integration setup"
  },
  {
    src: "/img/settings.png",
    alt: props.lang === "zh-CN" ? "AI Relay Box 设置页面" : "AI Relay Box settings page"
  }
];
---

<!doctype html>
<html lang={props.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seoMeta.title}</title>
    <meta name="description" content={seoMeta.description} />
    <meta name="keywords" content={seoMeta.keywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AI Relay Box" />
    <meta property="og:title" content={seoMeta.title} />
    <meta property="og:description" content={seoMeta.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(withBase("/img/home-preview.png"), canonicalUrl).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoMeta.title} />
    <meta name="twitter:description" content={seoMeta.description} />
    <meta name="twitter:image" content={new URL(withBase("/img/home-preview.png"), canonicalUrl).toString()} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body
    class="min-h-screen text-slate-100 antialiased"
    style="background:
      radial-gradient(circle at top left, rgba(45, 212, 191, 0.15), transparent 0, transparent 28%),
      radial-gradient(circle at top right, rgba(20, 184, 166, 0.14), transparent 0, transparent 24%),
      radial-gradient(circle at bottom, rgba(15, 23, 42, 0.42), transparent 0, transparent 32%),
      linear-gradient(180deg, #020617 0%, #06101d 44%, #020617 100%);"
  >
    <main class="mx-auto w-[min(1120px,calc(100vw-40px))] px-0 pb-14 pt-6">
      <header class="mb-9 flex flex-col items-start justify-between gap-3 md:flex-row md:items-center">
        <a
          class="inline-flex items-center gap-3 text-[12px] font-semibold uppercase tracking-[0.18em] text-slate-100"
          href={withBase(props.homeHref)}
        >
          <img
            class="h-8 w-8 rounded-lg border border-white/10 bg-slate-950/70 p-1.5 shadow-[0_12px_32px_rgba(0,0,0,0.28)]"
            src={logo.src}
            alt="AI Relay Box"
          />
          <span>AI Relay Box Docs</span>
        </a>
        <nav class="flex flex-wrap gap-5 text-[14px] font-semibold text-slate-300">
          <a class="transition hover:text-slate-100" href={withBase(props.introHref)}>{props.nav.intro}</a>
          <a class="transition hover:text-slate-100" href={withBase(props.quickStartHref)}>{props.nav.quickStart}</a>
          <a class="transition hover:text-slate-100" href={withBase(props.integrationHref)}>{props.nav.integration}</a>
          <a class="transition hover:text-slate-100" href={withBase(props.providersHref)}>{props.nav.providers}</a>
          <a class="transition hover:text-teal-300" href={props.githubHref}>{props.nav.github}</a>
        </nav>
      </header>

      <section>
        <article class="content-panel rounded-[1.75rem] border border-slate-500/20 bg-[linear-gradient(145deg,rgba(15,23,42,0.78),rgba(15,23,42,0.52))] p-7 shadow-[0_22px_70px_rgba(0,0,0,0.3)] backdrop-blur-xl md:p-9">
          <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-teal-300">{props.eyebrow}</p>
          <h1 class="max-w-[20ch] text-[clamp(2rem,4vw,3.25rem)] font-semibold leading-[1.03] tracking-[-0.04em] text-slate-50">
            {props.title}
          </h1>
          <div class="mt-5 grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(300px,0.48fr)] lg:items-start">
            <ul class="m-0 grid max-w-[68ch] list-none gap-3 p-0">
              {seoMeta.heroPoints.map((item) => (
                <li class="flex gap-3 text-[15px] leading-7 text-slate-300">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-teal-300 shadow-[0_0_20px_rgba(45,212,191,0.45)]"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="rounded-2xl border border-slate-400/15 bg-slate-950/42 p-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">{seoMeta.endpointLabel}</p>
              <code class="mt-2 block overflow-x-auto whitespace-nowrap text-[14px] font-semibold text-teal-200">http://127.0.0.1:3456/v1</code>
            </div>
          </div>
          <div class="mt-7 flex flex-wrap gap-2.5">
            <a
              class="inline-flex min-h-11 items-center justify-center rounded-full bg-teal-500 px-5 text-[13px] font-semibold tracking-[0.01em] text-slate-950 transition hover:bg-teal-400"
              href="#install"
            >
              {seoMeta.githubCta}
            </a>
            <a
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-slate-400/20 bg-slate-950/30 px-5 text-[13px] font-semibold tracking-[0.01em] text-slate-100 transition hover:border-slate-300/30 hover:bg-slate-900/45"
              href={withBase(props.quickStartHref)}
            >
              {seoMeta.docsCta}
            </a>
          </div>
        </article>
      </section>

      <section class="mt-5 overflow-hidden rounded-[1.75rem] border border-slate-500/20 bg-[linear-gradient(145deg,rgba(15,23,42,0.7),rgba(15,23,42,0.45))] p-4 shadow-[0_22px_70px_rgba(0,0,0,0.26)] backdrop-blur-xl md:p-5">
        <div class="mb-4 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-teal-300">{seoMeta.galleryLabel}</p>
            <h2 class="mt-2 max-w-[20ch] text-[1.65rem] font-semibold leading-tight tracking-[-0.04em] text-slate-50 md:max-w-none">
              {seoMeta.galleryTitle}
            </h2>
          </div>
          <p class="max-w-[42ch] text-[13px] leading-6 text-slate-400">{seoMeta.galleryLead}</p>
        </div>

        <div class="gallery-carousel rounded-[1.25rem] border border-white/10 bg-slate-950/60 p-3" data-gallery>
          <div class="mb-3 flex items-center gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-rose-400/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-300/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
          </div>
          <div class="relative overflow-hidden rounded-[1rem] border border-slate-400/10 bg-slate-950/70">
            {galleryImages.map((image, index) => (
              <figure
                class:list={[
                  "gallery-slide m-0",
                  index === 0 ? "is-active" : ""
                ]}
                data-gallery-slide
              >
                <img
                  src={withBase(image.src)}
                  alt={image.alt}
                  class="block aspect-[16/9] w-full object-cover"
                  loading={index === 0 ? "eager" : "lazy"}
                />
              </figure>
            ))}

            <button
              class="gallery-button left-3"
              type="button"
              aria-label={seoMeta.previousSlide}
              data-gallery-prev
            >
              &lt;
            </button>
            <button
              class="gallery-button right-3"
              type="button"
              aria-label={seoMeta.nextSlide}
              data-gallery-next
            >
              &gt;
            </button>
          </div>

          <div class="mt-3 flex justify-center gap-2">
            {galleryImages.map((image, index) => (
              <button
                class:list={[
                  "gallery-dot",
                  index === 0 ? "is-active" : ""
                ]}
                type="button"
                aria-label={image.alt}
                data-gallery-dot
                data-gallery-index={index}
              ></button>
            ))}
          </div>
        </div>
      </section>

      <section id="install" class="mt-5 rounded-[1.75rem] border border-teal-400/20 bg-[linear-gradient(145deg,rgba(20,184,166,0.16),rgba(15,23,42,0.56))] p-5 shadow-[0_20px_62px_rgba(0,0,0,0.24)] backdrop-blur-xl md:p-6">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="m-0 text-[1.65rem] font-semibold tracking-[-0.04em] text-slate-50">{seoMeta.installSectionTitle}</h2>
            <p class="mt-2 max-w-[72ch] text-[14px] leading-7 text-slate-300">{seoMeta.installSectionLead}</p>
          </div>
          <a
            class="inline-flex min-h-10 shrink-0 items-center justify-center rounded-full bg-slate-50 px-4 text-[13px] font-semibold text-slate-950 transition hover:bg-teal-100"
            href={latestReleaseHref}
          >
            {seoMeta.releaseCta}
          </a>
        </div>

        <div class="mt-5 grid grid-cols-1 gap-4">
          <article class="rounded-[1.3rem] border border-slate-400/15 bg-slate-950/32 p-4">
            <h3 class="m-0 text-[1.05rem] font-semibold tracking-[-0.02em] text-slate-50">{seoMeta.desktopTitle}</h3>
            <div class="mt-3 grid grid-cols-1 gap-2.5 md:grid-cols-2 xl:grid-cols-4">
              {downloadLinks.map((item) => (
                <a
                  class="group flex min-h-[4.5rem] items-center justify-between gap-3 rounded-2xl border border-slate-400/15 bg-slate-950/40 px-4 py-3 transition hover:border-teal-300/45 hover:bg-slate-900/58"
                  href={item.href}
                >
                  <span>
                    <span class="block text-[14px] font-semibold text-slate-50">{item.label}</span>
                    <span class="mt-1 block text-[12px] text-slate-400">{item.meta}</span>
                  </span>
                  <span class="text-[18px] leading-none text-teal-300 transition group-hover:translate-x-0.5">-&gt;</span>
                </a>
              ))}
            </div>
          </article>

          <article class="rounded-[1.3rem] border border-slate-400/15 bg-slate-950/32 p-4">
            <h3 class="m-0 text-[1.05rem] font-semibold tracking-[-0.02em] text-slate-50">{seoMeta.serverTitle}</h3>
            <div class="mt-3 rounded-2xl border border-slate-400/15 bg-slate-950/72 p-3">
              <code class="block break-all text-[12px] leading-6 text-teal-100">{installCommand}</code>
            </div>
            <p class="mt-3 text-[13px] leading-6 text-slate-400">{seoMeta.serverHint}</p>
          </article>
        </div>
      </section>

      <section class="mt-5 rounded-[1.45rem] border border-slate-500/18 bg-[linear-gradient(145deg,rgba(15,23,42,0.58),rgba(15,23,42,0.38))] p-5 shadow-[0_18px_52px_rgba(0,0,0,0.18)] backdrop-blur-xl md:flex md:items-center md:justify-between md:gap-5">
        <div>
          <h2 class="m-0 text-[1.25rem] font-semibold tracking-[-0.03em] text-slate-50">{seoMeta.docsTitle}</h2>
          <p class="mt-2 max-w-[62ch] text-[14px] leading-6 text-slate-400">{seoMeta.docsLead}</p>
        </div>
        <a
          class="mt-4 inline-flex min-h-10 shrink-0 items-center justify-center rounded-full border border-teal-300/30 bg-teal-400/10 px-4 text-[13px] font-semibold text-teal-200 transition hover:border-teal-200/50 hover:bg-teal-400/16 md:mt-0"
          href={withBase(props.quickStartHref)}
        >
          {seoMeta.docsCta}
        </a>
      </section>

      <style>
        .gallery-carousel {
          overflow: hidden;
        }

        .gallery-slide {
          display: none;
        }

        .gallery-slide.is-active {
          display: block;
        }

        .gallery-button {
          position: absolute;
          top: 50%;
          display: inline-flex;
          height: 2.5rem;
          width: 2.5rem;
          transform: translateY(-50%);
          align-items: center;
          justify-content: center;
          border-radius: 9999px;
          border: 1px solid rgba(148, 163, 184, 0.24);
          background: rgba(2, 6, 23, 0.72);
          color: rgb(204, 251, 241);
          font-size: 1.125rem;
          font-weight: 700;
          transition:
            background-color 180ms ease,
            border-color 180ms ease,
            color 180ms ease;
        }

        .gallery-button:hover {
          border-color: rgba(94, 234, 212, 0.5);
          background: rgba(15, 23, 42, 0.86);
          color: rgb(240, 253, 250);
        }

        .gallery-button:focus-visible,
        .gallery-dot:focus-visible {
          outline: 2px solid rgb(45, 212, 191);
          outline-offset: 3px;
        }

        .gallery-dot {
          height: 0.5rem;
          width: 0.5rem;
          border-radius: 9999px;
          background: rgba(148, 163, 184, 0.42);
          transition:
            background-color 180ms ease,
            width 180ms ease;
        }

        .gallery-dot.is-active {
          width: 1.5rem;
          background: rgb(45, 212, 191);
        }

        @media (prefers-reduced-motion: reduce) {
          .gallery-button,
          .gallery-dot {
            transition: none;
          }
        }
      </style>
      <script>
        for (const gallery of document.querySelectorAll("[data-gallery]")) {
          const slides = Array.from(gallery.querySelectorAll("[data-gallery-slide]"));
          const dots = Array.from(gallery.querySelectorAll("[data-gallery-dot]"));
          const previous = gallery.querySelector("[data-gallery-prev]");
          const next = gallery.querySelector("[data-gallery-next]");
          let activeIndex = 0;

          const showSlide = (nextIndex) => {
            activeIndex = (nextIndex + slides.length) % slides.length;
            slides.forEach((slide, index) => {
              slide.classList.toggle("is-active", index === activeIndex);
            });
            dots.forEach((dot, index) => {
              dot.classList.toggle("is-active", index === activeIndex);
            });
          };

          previous?.addEventListener("click", () => showSlide(activeIndex - 1));
          next?.addEventListener("click", () => showSlide(activeIndex + 1));
          dots.forEach((dot) => {
            dot.addEventListener("click", () => {
              const index = Number(dot.getAttribute("data-gallery-index") ?? 0);
              showSlide(index);
            });
          });
        }
      </script>
    </main>
  </body>
</html>
