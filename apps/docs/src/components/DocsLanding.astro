---
interface Props {
  lang: "en" | "zh-CN";
  homeHref: string;
  introHref: string;
  quickStartHref: string;
  integrationHref: string;
  providersHref: string;
  faqHref: string;
  githubHref: string;
  nav: {
    intro: string;
    quickStart: string;
    integration: string;
    providers: string;
    github: string;
  };
  eyebrow: string;
  title: string;
  description: string;
  primaryCta: string;
  secondaryCta: string;
  coverageTitle: string;
  coverageItems: string[];
  sectionTitle: string;
  sectionLead: string;
  cards: Array<{
    title: string;
    body: string;
    href: string;
    cta: string;
  }>;
}

const props = Astro.props as Props;
import logo from "../assets/logo.svg";
import rootPackage from "../../../../package.json";
import "../styles/site.css";
const withBase = (path: string) => {
  const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
  const relative = path.replace(/^\//, "");
  return `${base}${relative}`;
};
const isNewTabLink = (path: string) => path === "/deeplink.html";
const siteUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const canonicalUrl = siteUrl.toString();
const releaseVersion = rootPackage.version;
const releaseTag = `v${releaseVersion}`;
const releaseBase = `https://github.com/xiaoyuandev/ai-relay-box/releases/download/${releaseTag}`;
const latestReleaseHref = "https://github.com/xiaoyuandev/ai-relay-box/releases/latest";
const installCommand = "curl -fsSL https://raw.githubusercontent.com/xiaoyuandev/ai-relay-box/main/scripts/install.sh | bash";
const downloadLinks = [
  {
    label: props.lang === "zh-CN" ? "macOS Apple Silicon" : "macOS Apple Silicon",
    meta: props.lang === "zh-CN" ? "DMG, arm64" : "DMG, arm64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-arm64.dmg`
  },
  {
    label: props.lang === "zh-CN" ? "macOS Intel" : "macOS Intel",
    meta: props.lang === "zh-CN" ? "DMG, x64" : "DMG, x64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-x64.dmg`
  },
  {
    label: props.lang === "zh-CN" ? "Windows" : "Windows",
    meta: props.lang === "zh-CN" ? "安装程序, x64" : "Installer, x64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-x64-setup.exe`
  },
  {
    label: props.lang === "zh-CN" ? "Linux Desktop" : "Linux Desktop",
    meta: props.lang === "zh-CN" ? "AppImage, x64" : "AppImage, x64",
    href: `${releaseBase}/AI-Relay-Box-${releaseVersion}-x64.AppImage`
  }
];
const seoMeta =
  props.lang === "zh-CN"
    ? {
        title: "AI Relay Box - 本地 OpenAI 兼容 AI 网关",
        description:
          "AI Relay Box 让 Cursor、Claude Code、Codex、Cherry Studio 和脚本共用一个本地 OpenAI 兼容端点，并通过桌面 UI 管理多个 AI 服务商和模型来源。",
        keywords:
          "AI Relay Box, 本地 AI 网关, OpenAI 兼容网关, Cursor 中转配置, Claude Code OpenAI, Codex 本地网关, new-api, one-api",
        downloadTitle: "下载并开始使用",
        downloadLead:
          "从 GitHub Release 下载桌面端，或在 WSL / Linux Server 上使用一键安装命令启动本地网关。",
        githubCta: "前往 GitHub 下载",
        releaseCta: "查看全部 Release",
        serverTitle: "WSL / Linux Server 一键安装",
        serverHint: "安装后默认 Web 管理界面和 OpenAI 兼容入口都运行在 http://127.0.0.1:3456。",
      }
    : {
        title: "AI Relay Box - Local AI Gateway for OpenAI-Compatible Tools",
        description:
          "AI Relay Box gives Cursor, Claude Code, Codex, Cherry Studio, and scripts one local OpenAI-compatible endpoint, with provider and model switching from a desktop UI.",
        keywords:
          "AI Relay Box, local AI gateway, OpenAI compatible gateway, Cursor OpenAI proxy, Claude Code OpenAI compatible, Codex local gateway, new-api, one-api",
        downloadTitle: "Download and start using AI Relay Box",
        downloadLead:
          "Download the desktop app from GitHub Releases, or run the one-line installer for WSL and Linux Server.",
        githubCta: "Download from GitHub",
        releaseCta: "View all releases",
        serverTitle: "WSL / Linux Server one-line install",
        serverHint: "After installation, the Web UI and OpenAI-compatible endpoint run on http://127.0.0.1:3456 by default.",
      };
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "AI Relay Box",
  applicationCategory: "DeveloperApplication",
  operatingSystem: ["macOS", "Windows", "Linux"],
  description: seoMeta.description,
  url: canonicalUrl,
  downloadUrl: latestReleaseHref,
  softwareVersion: releaseVersion,
  codeRepository: "https://github.com/xiaoyuandev/ai-relay-box",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};

const previewMeta =
  props.lang === "zh-CN"
    ? {
        label: "界面预览",
        title: "桌面端控制面板与本地网关入口",
        body: "后续这里可以替换成真实的应用截图。当前先保留一个与产品视觉一致的预览占位区，用来承接产品信息密度。",
        pills: ["Provider 切换", "请求日志", "Health Check"]
      }
    : {
        label: "Interface Preview",
        title: "Desktop control plane and stable local gateway entry point",
        body: "This area is ready to be replaced with real application screenshots. For now it acts as a visual preview block that matches the product tone.",
        pills: ["Provider Switch", "Request Logs", "Health Check"]
      };
---

<!doctype html>
<html lang={props.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seoMeta.title}</title>
    <meta name="description" content={seoMeta.description} />
    <meta name="keywords" content={seoMeta.keywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AI Relay Box" />
    <meta property="og:title" content={seoMeta.title} />
    <meta property="og:description" content={seoMeta.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(withBase("/img/home-preview.png"), canonicalUrl).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoMeta.title} />
    <meta name="twitter:description" content={seoMeta.description} />
    <meta name="twitter:image" content={new URL(withBase("/img/home-preview.png"), canonicalUrl).toString()} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body
    class="min-h-screen text-slate-100 antialiased"
    style="background:
      radial-gradient(circle at top left, rgba(45, 212, 191, 0.15), transparent 0, transparent 28%),
      radial-gradient(circle at top right, rgba(20, 184, 166, 0.14), transparent 0, transparent 24%),
      radial-gradient(circle at bottom, rgba(15, 23, 42, 0.42), transparent 0, transparent 32%),
      linear-gradient(180deg, #020617 0%, #06101d 44%, #020617 100%);"
  >
    <main class="mx-auto w-[min(1040px,calc(100vw-40px))] px-0 pb-14 pt-6">
      <header class="mb-9 flex flex-col items-start justify-between gap-3 md:flex-row md:items-center">
        <a
          class="inline-flex items-center gap-3 text-[12px] font-semibold uppercase tracking-[0.18em] text-slate-100"
          href={withBase(props.homeHref)}
        >
          <img
            class="h-8 w-8 rounded-lg border border-white/10 bg-slate-950/70 p-1.5 shadow-[0_12px_32px_rgba(0,0,0,0.28)]"
            src={logo.src}
            alt="AI Relay Box"
          />
          <span>AI Relay Box Docs</span>
        </a>
        <nav class="flex flex-wrap gap-4 text-[13px] text-slate-400">
          <a class="transition hover:text-slate-100" href={withBase(props.introHref)}>{props.nav.intro}</a>
          <a class="transition hover:text-slate-100" href={withBase(props.quickStartHref)}>{props.nav.quickStart}</a>
          <a class="transition hover:text-slate-100" href={withBase(props.integrationHref)}>{props.nav.integration}</a>
          <a class="transition hover:text-slate-100" href={withBase(props.providersHref)}>{props.nav.providers}</a>
          <a class="transition hover:text-teal-300" href={props.githubHref}>{props.nav.github}</a>
        </nav>
      </header>

      <section class="grid grid-cols-1 gap-5 xl:grid-cols-[minmax(0,1.08fr)_minmax(280px,0.82fr)]">
        <article class="content-panel rounded-[1.75rem] border border-slate-500/20 bg-[linear-gradient(145deg,rgba(15,23,42,0.78),rgba(15,23,42,0.52))] p-8 shadow-[0_22px_70px_rgba(0,0,0,0.3)] backdrop-blur-xl">
          <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-teal-300">{props.eyebrow}</p>
          <h1 class="max-w-[13ch] text-[clamp(2.5rem,5vw,4.25rem)] font-semibold leading-[0.96] tracking-[-0.05em] text-slate-50">
            {props.title}
          </h1>
          <p class="mt-4 max-w-[54ch] text-[15px] leading-7 text-slate-300">{props.description}</p>
          <div class="mt-6 flex flex-wrap gap-2.5">
            <a
              class="inline-flex min-h-10 items-center justify-center rounded-full bg-teal-500 px-4 text-[13px] font-semibold tracking-[0.01em] text-slate-950 transition hover:bg-teal-400"
              href="#download"
            >
              {seoMeta.githubCta}
            </a>
            <a
              class="inline-flex min-h-10 items-center justify-center rounded-full border border-slate-400/20 bg-slate-950/30 px-4 text-[13px] font-semibold tracking-[0.01em] text-slate-100 transition hover:border-slate-300/30 hover:bg-slate-900/45"
              href={props.githubHref}
            >
              GitHub
            </a>
          </div>
        </article>

        <aside class="content-panel overflow-hidden rounded-[1.6rem] border border-slate-500/20 bg-[linear-gradient(145deg,rgba(15,23,42,0.66),rgba(15,23,42,0.44))] p-4 shadow-[0_20px_56px_rgba(0,0,0,0.24)] backdrop-blur-xl">
          <div class="mb-4 flex items-start justify-between gap-3">
            <div>
              <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-teal-300">{previewMeta.label}</p>
              <h2 class="mt-2 text-[15px] font-semibold leading-6 text-slate-50">{previewMeta.title}</h2>
            </div>
          </div>

          <div class="rounded-[1.1rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(45,212,191,0.18),transparent_24%),linear-gradient(180deg,rgba(15,23,42,0.94),rgba(2,6,23,0.98))] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
            <div class="mb-3 flex items-center gap-1.5">
              <span class="h-2.5 w-2.5 rounded-full bg-rose-400/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-300/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
            </div>

            <div class="overflow-hidden rounded-[0.95rem] border border-slate-400/10 bg-slate-950/60">
              <img
                src={withBase("/img/home-preview.png")}
                alt="AI Relay Box preview"
                class="block aspect-[16/10] w-full object-cover opacity-90"
              />
            </div>
          </div>

          <p class="mt-4 text-[13px] leading-6 text-slate-400">{previewMeta.body}</p>

          <div class="mt-4 flex flex-wrap gap-2">
            {previewMeta.pills.map((pill) => (
              <span class="inline-flex rounded-full border border-teal-400/15 bg-teal-400/8 px-3 py-1 text-[12px] font-medium text-teal-200">
                {pill}
              </span>
            ))}
          </div>
        </aside>
      </section>

      <section id="download" class="mt-5 grid grid-cols-1 gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(320px,0.72fr)]">
        <article class="content-panel rounded-[1.45rem] border border-teal-400/20 bg-[linear-gradient(145deg,rgba(20,184,166,0.16),rgba(15,23,42,0.54))] p-5 shadow-[0_18px_52px_rgba(0,0,0,0.22)] backdrop-blur-xl">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <h2 class="m-0 text-[1.35rem] font-semibold tracking-[-0.03em] text-slate-50">{seoMeta.downloadTitle}</h2>
              <p class="mt-2 max-w-[68ch] text-[14px] leading-6 text-slate-300">{seoMeta.downloadLead}</p>
            </div>
            <a
              class="inline-flex min-h-10 shrink-0 items-center justify-center rounded-full bg-slate-50 px-4 text-[13px] font-semibold text-slate-950 transition hover:bg-teal-100"
              href={latestReleaseHref}
            >
              {seoMeta.releaseCta}
            </a>
          </div>

          <div class="mt-4 grid grid-cols-1 gap-2.5 md:grid-cols-2">
            {downloadLinks.map((item) => (
              <a
                class="group flex min-h-[4.5rem] items-center justify-between gap-3 rounded-2xl border border-slate-400/15 bg-slate-950/34 px-4 py-3 transition hover:border-teal-300/45 hover:bg-slate-900/52"
                href={item.href}
              >
                <span>
                  <span class="block text-[14px] font-semibold text-slate-50">{item.label}</span>
                  <span class="mt-1 block text-[12px] text-slate-400">{item.meta}</span>
                </span>
                <span class="text-[18px] leading-none text-teal-300 transition group-hover:translate-x-0.5">-&gt;</span>
              </a>
            ))}
          </div>
        </article>

        <aside class="content-panel rounded-[1.45rem] border border-slate-500/20 bg-[linear-gradient(145deg,rgba(15,23,42,0.62),rgba(15,23,42,0.42))] p-5 shadow-[0_18px_52px_rgba(0,0,0,0.2)] backdrop-blur-xl">
          <h2 class="m-0 text-[1.05rem] font-semibold tracking-[-0.02em] text-slate-50">{seoMeta.serverTitle}</h2>
          <div class="mt-3 overflow-x-auto rounded-2xl border border-slate-400/15 bg-slate-950/72 p-3">
            <code class="whitespace-nowrap text-[12px] leading-6 text-teal-100">{installCommand}</code>
          </div>
          <p class="mt-3 text-[13px] leading-6 text-slate-400">{seoMeta.serverHint}</p>
        </aside>
      </section>

      <h2 class="mt-9 text-[1.65rem] font-semibold tracking-[-0.04em] text-slate-50">{props.sectionTitle}</h2>
      <p class="mt-2.5 max-w-[64ch] text-[15px] leading-7 text-slate-400">{props.sectionLead}</p>

      <section class="mt-5 grid grid-cols-1 gap-3.5 lg:grid-cols-2 xl:grid-cols-3">
        {props.cards.map((card) => (
          <article class="content-panel rounded-[1.35rem] border border-slate-500/15 bg-[linear-gradient(145deg,rgba(15,23,42,0.54),rgba(15,23,42,0.4))] p-5 shadow-[0_16px_36px_rgba(0,0,0,0.22)] backdrop-blur-xl">
            <h3 class="m-0 text-[1.05rem] font-semibold tracking-[-0.02em] text-slate-50">{card.title}</h3>
            <p class="mt-2.5 text-[14px] leading-6 text-slate-300">{card.body}</p>
            <a
              class="mt-4 inline-flex text-[13px] font-semibold text-teal-300 transition hover:text-teal-200"
              href={withBase(card.href)}
              target={isNewTabLink(card.href) ? "_blank" : undefined}
              rel={isNewTabLink(card.href) ? "noreferrer" : undefined}
            >
              {card.cta}
            </a>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>
